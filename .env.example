# =============================================================================
#  POS Management System — host environment for docker-compose
#  Copy to `.env` next to docker-compose.yml on the VPS, fill in real values.
#  NEVER commit the filled-in .env — it's in .gitignore for that reason.
# =============================================================================

# ─── MongoDB (kept internal to the docker network) ───────────────────────────
MONGO_ROOT_USER=posroot
# Use 32+ random chars. Generate: openssl rand -base64 32
MONGO_ROOT_PASSWORD=REPLACE_WITH_A_LONG_RANDOM_STRING

# Full URI is auto-built from the user/password above. Override only if you
# point at an external Mongo Atlas / managed instance instead of the bundled
# container.
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/pos_system

# ─── JWT — sessions cookie signing ────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d
COOKIE_MAX_AGE_DAYS=7

# ─── Public URLs ──────────────────────────────────────────────────────────────
# The browser-facing URL. CORS + cookie `SameSite` rely on this matching the
# real address. Use https:// once you put a TLS proxy in front.
CLIENT_URL=http://31.97.119.223

# ─── First-boot super admin ───────────────────────────────────────────────────
# Created on first server start if no super admin exists yet. Change the
# password immediately after first login.
SUPER_ADMIN_EMAIL=superadmin@possystem.com
SUPER_ADMIN_PASSWORD=REPLACE_ON_FIRST_BOOT

# ─── Cloudinary (optional — khata proof uploads) ──────────────────────────────
# Leave empty to keep proofs in the local docker volume (`backend-uploads`).
# Fill all three to push images / voice notes to Cloudinary instead.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Image overrides — set by CI when deploying prebuilt images from GHCR ────
# Leave blank in local / VPS-only setup; docker-compose then builds locally.
# BACKEND_IMAGE=ghcr.io/fareed-s/pos-backend:latest
# FRONTEND_IMAGE=ghcr.io/fareed-s/pos-frontend:latest
# HOST_HTTP_PORT=80
# VITE_API_URL=
